const KioskView = ({ onExit, members, setMembers, classes, staffList }) => {
  const [nameInput, setNameInput] = useState('');
  const [step, setStep] = useState('identify'); // identify, select-class, success
  const [foundMember, setFoundMember] = useState(null);
  const [selectedClassId, setSelectedClassId] = useState('');
  
  const [showExitModal, setShowExitModal] = useState(false);
  const [exitPin, setExitPin] = useState('');
  const [exitError, setExitError] = useState('');

  const [suggestions, setSuggestions] = useState([]);
  const [showSuggestions, setShowSuggestions] = useState(false);

  const todayStr = new Date().toLocaleDateString('en-US', { weekday: 'long' });
  const todayClasses = classes.filter(c => c.day === todayStr);

  useEffect(() => {
    if (nameInput.trim().length > 0 && step === 'identify') {
      const filtered = members.filter(m => 
        m.status === 'Active' && 
        m.name.toLowerCase().includes(nameInput.toLowerCase())
      );
      setSuggestions(filtered);
      setShowSuggestions(true);
    } else {
      setSuggestions([]);
      setShowSuggestions(false);
    }
  }, [nameInput, members, step]);

  const handleIdentify = (e) => {
    e.preventDefault();
    const m = members.find(mbr => mbr.name.toLowerCase() === nameInput.toLowerCase() && mbr.status === 'Active');
    if (m) {
      setFoundMember(m);
      setStep('select-class');
      setShowSuggestions(false);
    } else {
      alert("Active member not found. Please select from the suggestions or see the front desk.");
    }
  };

  const selectSuggestion = (member) => {
    setNameInput(member.name);
    setFoundMember(member);
    setStep('select-class');
    setShowSuggestions(false);
  };

  const handleCheckIn = (e) => {
    e.preventDefault();
    const cls = classes.find(c => c.id === selectedClassId);
    if (!cls || !foundMember) return;

    const dateStr = new Date().toISOString().split('T')[0];
    const newHistory = { id: `kiosk-${Date.now()}`, date: dateStr, className: cls.title };

    const updated = members.map(m => {
      if (m.id === foundMember.id) {
        // Increment classesSincePromotion to effectively reduce required classes remaining
        const newClassesSincePromotion = m.rank.classesSincePromotion + 1;
        return {
          ...m,
          rank: { ...m.rank, classesSincePromotion: newClassesSincePromotion },
          attendance: {
            ...m.attendance,
            total: m.attendance.total + 1,
            thisMonth: m.attendance.thisMonth + 1,
            lastAttended: dateStr,
            history: [newHistory, ...(m.attendance.history || [])]
          }
        };
      }
      return m;
    });
    
    // Update local foundMember state so success screen shows correct info immediately
    setFoundMember(prev => ({
        ...prev,
        rank: { ...prev.rank, classesSincePromotion: prev.rank.classesSincePromotion + 1 }
    }));
    
    setMembers(updated);
    setStep('success');
    
    setTimeout(() => {
      setStep('identify');
      setNameInput('');
      setFoundMember(null);
      setSelectedClassId('');
    }, 4000);
  };

  const handleExitAttempt = (e) => {
    e.preventDefault();
    const staff = staffList.find(s => s.pin === exitPin);
    if (staff) {
      onExit();
    } else {
      setExitError("Invalid Staff PIN.");
    }
  };

  return (
    <div className="fixed inset-0 z-50 bg-slate-900 flex flex-col items-center justify-center font-sans">
       <button onClick={() => setShowExitModal(true)} className="absolute top-6 right-6 text-slate-500 hover:text-slate-300 flex items-center gap-2 text-sm font-medium">
         <Lock className="w-4 h-4" /> Staff Exit
       </button>

       <div className="w-full max-w-lg bg-white rounded-3xl shadow-2xl overflow-hidden animate-in zoom-in-95 duration-500">
         <div className="p-10 text-center bg-blue-600 text-white">
            <h1 className="text-3xl font-bold mb-2">Self Check-in</h1>
            <p className="text-blue-100 font-medium">Welcome! Please sign in for your class.</p>
         </div>

         <div className="p-10">
            {step === 'identify' && (
              <form onSubmit={handleIdentify} className="space-y-6 relative">
                <div>
                  <label className="block text-sm font-semibold text-slate-700 mb-2">Enter your Name</label>
                  <input 
                    required autoFocus type="text" placeholder="e.g. Sarah"
                    className="w-full text-lg p-4 bg-slate-50 border border-slate-200 rounded-xl focus:ring-4 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all"
                    value={nameInput} onChange={e => setNameInput(e.target.value)}
                    autoComplete="off"
                  />
                  {showSuggestions && suggestions.length > 0 && (
                    <div className="absolute z-10 w-full mt-1 bg-white border border-slate-200 rounded-xl shadow-lg max-h-60 overflow-y-auto">
                      {suggestions.map(member => (
                        <div 
                          key={member.id} 
                          className="px-4 py-3 hover:bg-slate-50 cursor-pointer border-b border-slate-100 last:border-0 flex items-center justify-between"
                          onClick={() => selectSuggestion(member)}
                        >
                          <span className="font-medium text-slate-900">{member.name}</span>
                          <span className="text-xs text-slate-500">{member.type}</span>
                        </div>
                      ))}
                    </div>
                  )}
                </div>
                <Button type="submit" className="w-full py-4 text-lg" size="lg">Continue</Button>
              </form>
            )}

            {step === 'select-class' && (
              <form onSubmit={handleCheckIn} className="space-y-6">
                <div className="text-center mb-6">
                  <h3 className="text-xl font-bold text-slate-900">Hello, {foundMember.name.split(' ')[0]}!</h3>
                  <p className="text-slate-500 mt-1">Select the class you are attending today.</p>
                </div>
                
                <div className="space-y-3">
                  {todayClasses.map(cls => (
                    <label key={cls.id} className={`flex items-center justify-between p-4 border rounded-xl cursor-pointer transition-colors ${selectedClassId === cls.id ? 'border-blue-600 bg-blue-50' : 'border-slate-200 hover:bg-slate-50'}`}>
                      <div>
                        <div className="font-bold text-slate-900">{cls.title}</div>
                        <div className="text-sm text-slate-500">{cls.startTime}</div>
                      </div>
                      <input 
                        type="radio" name="classSelect" value={cls.id}
                        className="w-5 h-5 text-blue-600"
                        checked={selectedClassId === cls.id} onChange={(e) => setSelectedClassId(e.target.value)}
                      />
                    </label>
                  ))}
                  {todayClasses.length === 0 && <div className="text-center text-slate-500 py-4">No classes scheduled for today.</div>}
                </div>

                <div className="flex gap-4">
                  <Button type="button" variant="outline" className="flex-1 py-4 text-lg" size="lg" onClick={() => {setStep('identify'); setNameInput('');}}>Cancel</Button>
                  <Button type="submit" disabled={!selectedClassId} className="flex-1 py-4 text-lg" size="lg">Check-in</Button>
                </div>
              </form>
            )}

            {step === 'success' && (
              <div className="text-center py-8 animate-in fade-in zoom-in duration-300">
                <div className="w-20 h-20 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-6">
                  <CheckCircle className="w-10 h-10" />
                </div>
                <h3 className="text-2xl font-bold text-slate-900 mb-2">You're checked in!</h3>
                <p className="text-slate-600 mb-4">Have a great class.</p>
                <div className="text-sm text-slate-500 bg-slate-50 p-3 rounded-lg inline-block">
                  <strong className="text-indigo-600">{Math.max(0, foundMember.rank.requiredClasses - foundMember.rank.classesSincePromotion)} classes</strong> left until your next rank evaluation!
                </div>
              </div>
            )}
         </div>
       </div>

       {showExitModal && (
         <div className="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/90 backdrop-blur-sm animate-in fade-in duration-200">
          <div className="bg-white border border-slate-200 p-8 rounded-2xl max-w-sm w-full mx-4 shadow-2xl text-center">
            <h3 className="text-xl font-bold text-slate-900 mb-2">Secure Staff Exit</h3>
            <p className="text-sm text-slate-600 mb-6">Enter PIN to close kiosk mode.</p>
            {exitError && <p className="text-rose-600 text-sm font-semibold mb-4">{exitError}</p>}
            <form onSubmit={handleExitAttempt}>
               <input 
                 autoFocus type="password" 
                 className="w-full bg-slate-50 border border-slate-300 text-slate-900 text-center text-3xl tracking-[0.5em] font-mono rounded-xl py-3 outline-none focus:border-blue-500 mb-6"
                 value={exitPin} onChange={e => setExitPin(e.target.value)} placeholder="••••"
               />
               <div className="flex gap-3">
                 <Button type="button" variant="outline" className="flex-1" onClick={() => {setShowExitModal(false); setExitPin(''); setExitError('');}}>Cancel</Button>
                 <Button type="submit" className="flex-1 bg-slate-900 text-white hover:bg-slate-800">Exit Kiosk</Button>
               </div>
            </form>
          </div>
         </div>
       )}
    </div>
  );
};

